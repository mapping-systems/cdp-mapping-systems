---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  section: string;
  description?: string;
}

const { title, section, description } = Astro.props;
---
<BaseLayout title={title} description={description}>
  <article class="prose prose-lg max-w-none">
    <header class="mb-10 not-prose border-b border-border pb-6">
      <p class="text-xs font-semibold text-accent uppercase tracking-[0.14em]">
        {section.replace(/_/g, ' ')}
      </p>
      <h1 class="mt-3 text-4xl md:text-5xl font-semibold tracking-tight text-text leading-[1.1]">
        {title}
      </h1>
      {description && (
        <p class="mt-4 text-lg text-muted leading-relaxed">{description}</p>
      )}
    </header>
    <slot />
  </article>
</BaseLayout>
