---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

interface ArenaGridBlock {
  id: number;
  class: 'Image' | 'Text' | 'Link' | 'Media' | 'Attachment' | 'Channel';
  title: string | null;
  description: string | null;
  source_url: string | null;
  image_url: string | null;
  thumb_url: string | null;
  content: string | null;
  block_url: string;
}

interface ArenaChannelData {
  slug: string;
  title: string;
  description: string;
  arenaId: number;
  arenaUrl: string;
  blockCount: number;
  tags: string[];
  fetchedAt: string;
  blocks: ArenaGridBlock[];
}

// Eager-load every channel JSON at build time. Vite's import.meta.glob
// resolves the literal pattern to a static map keyed by relative path,
// which we look up by the requested slug.
const channelData = import.meta.glob<{ default: ArenaChannelData }>(
  '../../data/arena/*.json',
  { eager: true },
);

export async function getStaticPaths() {
  const channels = await getCollection('resources');
  return channels.map((channel) => ({
    params: { slug: channel.data.slug },
    props: { channel },
  }));
}

const { channel } = Astro.props;
const dataKey = `../../data/arena/${channel.data.slug}.json`;
const data = channelData[dataKey]?.default;

// Pick a hostname for Link blocks so cards have a small "via foo.com" line.
function hostnameOf(url: string | null): string | null {
  if (!url) return null;
  try {
    return new URL(url).hostname.replace(/^www\./, '');
  } catch {
    return null;
  }
}
---
<BaseLayout title={channel.data.title} description={channel.data.description}>
  <header class="mb-8 border-b border-border pb-6">
    <p class="text-xs font-semibold text-accent uppercase tracking-[0.14em]">
      Resources
    </p>
    <h1 class="mt-3 text-4xl md:text-5xl font-semibold tracking-tight text-text leading-[1.1]">
      {channel.data.title}
    </h1>
    {channel.data.description && (
      <p class="mt-4 text-lg text-muted leading-relaxed max-w-3xl">{channel.data.description}</p>
    )}
    <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-subtle">
      <span>{channel.data.blockCount ?? data?.blocks.length ?? 0} items</span>
      {data?.arenaUrl && (
        <a
          href={data.arenaUrl}
          target="_blank"
          rel="noreferrer noopener"
          class="text-link hover:text-link-hover underline underline-offset-2"
        >
          View on are.na ↗
        </a>
      )}
      {channel.data.tags && channel.data.tags.length > 0 && (
        <ul class="flex flex-wrap gap-1.5">
          {channel.data.tags.map((tag) => (
            <li class="px-2 py-0.5 rounded-full bg-surface-strong text-muted text-xs">{tag}</li>
          ))}
        </ul>
      )}
    </div>
  </header>

  {!data ? (
    <p class="text-muted italic">
      Channel data missing. Run <code class="text-text bg-surface-strong px-1.5 py-0.5 rounded">npm run build:resources</code>.
    </p>
  ) : (
    <div class="arena-grid">
      {data.blocks.map((block) => {
        const host = hostnameOf(block.source_url);
        return (
          <article class="arena-card border border-border rounded-lg overflow-hidden bg-bg break-inside-avoid mb-4">
            {block.image_url && (
              <a
                href={block.source_url || block.image_url}
                target="_blank"
                rel="noreferrer noopener"
                class="block bg-surface no-underline"
              >
                <img
                  src={block.image_url}
                  alt={block.title ?? block.description?.slice(0, 80) ?? ''}
                  loading="lazy"
                  class="w-full h-auto object-contain"
                />
              </a>
            )}

            {block.class === 'Text' && block.content && (
              <div class="p-4 text-sm text-text whitespace-pre-line wrap-break-word">
                {block.content}
              </div>
            )}

            {(block.title || block.description || block.source_url) && (
              <div class="p-4 text-sm">
                {block.title && (
                  <h3 class="font-medium text-text leading-snug">
                    {block.source_url ? (
                      <a
                        href={block.source_url}
                        target="_blank"
                        rel="noreferrer noopener"
                        class="hover:text-accent transition-colors no-underline"
                      >
                        {block.title}
                      </a>
                    ) : block.title}
                  </h3>
                )}
                {block.description && (
                  <p class="mt-1.5 text-muted leading-snug line-clamp-3">{block.description}</p>
                )}
                {host && (
                  <p class="mt-2 text-xs text-subtle">via {host}</p>
                )}
              </div>
            )}

            {/* Channel reference / fallback for blocks with no other content. */}
            {!block.image_url && !block.content && !block.title && !block.description && (
              <a
                href={block.block_url}
                target="_blank"
                rel="noreferrer noopener"
                class="block p-4 text-sm text-muted no-underline hover:text-accent"
              >
                Block #{block.id} ↗
              </a>
            )}
          </article>
        );
      })}
    </div>
  )}
</BaseLayout>

<style>
  /* CSS columns give a natural masonry layout with no JS. Cards flow
     top-to-bottom, then column-by-column, preserving variable heights. */
  .arena-grid {
    column-count: 1;
    column-gap: 1rem;
  }
  @media (min-width: 640px) {
    .arena-grid { column-count: 2; }
  }
  @media (min-width: 900px) {
    .arena-grid { column-count: 3; }
  }
  @media (min-width: 1280px) {
    .arena-grid { column-count: 4; }
  }
  /* Avoid breaking a card across columns. */
  .arena-card { break-inside: avoid; page-break-inside: avoid; }
</style>
