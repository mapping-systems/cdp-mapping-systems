---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const channels = await getCollection('resources');
  return channels.map((channel) => ({
    params: { slug: channel.data.slug },
    props: { channel },
  }));
}

const { channel } = Astro.props;
const { Content } = await render(channel);

const arenaUrl = channel.data.arenaId
  ? `https://www.are.na/channel/${channel.data.arenaId}`
  : null;
---
<BaseLayout title={channel.data.title} description={channel.data.description}>
  <article class="prose prose-lg max-w-none">
    <header class="mb-10 not-prose border-b border-border pb-6">
      <p class="text-xs font-semibold text-accent uppercase tracking-[0.14em]">
        Resources
      </p>
      <h1 class="mt-3 text-4xl md:text-5xl font-semibold tracking-tight text-text leading-[1.1]">
        {channel.data.title}
      </h1>
      {channel.data.description && (
        <p class="mt-4 text-lg text-muted leading-relaxed">{channel.data.description}</p>
      )}
      {arenaUrl && (
        <p class="mt-4 text-sm text-subtle">
          {channel.data.blockCount ?? 0} items ·
          <a
            href={arenaUrl}
            target="_blank"
            rel="noreferrer noopener"
            class="text-link hover:text-link-hover underline underline-offset-2 ml-1"
          >
            View on are.na ↗
          </a>
        </p>
      )}
    </header>
    <Content />
  </article>
</BaseLayout>
