---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const channels = await getCollection('resources');
channels.sort((a, b) => a.data.title.localeCompare(b.data.title));
---
<BaseLayout title="Resources">
  <h1 class="text-5xl font-semibold tracking-tight mb-3 text-text">Resources</h1>
  <p class="text-lg text-muted mb-12 max-w-2xl">
    Reference material, inspiration, and supporting links collected for the
    course. Pulled from
    <a class="text-link hover:text-link-hover underline-offset-2" href="https://www.are.na" target="_blank" rel="noreferrer noopener">are.na</a>
    channels and refreshed periodically.
  </p>

  {channels.length === 0 ? (
    <p class="text-muted italic">
      No resources yet. Configure are.na channels in <code class="text-text bg-surface-strong px-1.5 py-0.5 rounded">resources.config.ts</code> and run <code class="text-text bg-surface-strong px-1.5 py-0.5 rounded">npm run build:resources</code>.
    </p>
  ) : (
    <ul class="grid sm:grid-cols-2 gap-6">
      {channels.map((channel) => (
        <li>
          <a
            href={`/resources/${channel.data.slug}`}
            class="block group no-underline border border-border rounded-lg overflow-hidden hover:border-accent transition-colors"
          >
            {channel.data.heroImage && (
              <div class="aspect-[3/2] overflow-hidden bg-surface">
                <img
                  src={channel.data.heroImage}
                  alt=""
                  loading="lazy"
                  class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
                />
              </div>
            )}
            <div class="p-4">
              <h2 class="text-lg font-medium text-text group-hover:text-accent transition-colors">
                {channel.data.title}
              </h2>
              {channel.data.description && (
                <p class="mt-1 text-sm text-muted line-clamp-2">
                  {channel.data.description}
                </p>
              )}
              <p class="mt-3 text-xs text-subtle uppercase tracking-wider">
                {channel.data.blockCount ?? 0} {channel.data.blockCount === 1 ? 'item' : 'items'}
              </p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
