# Copy this file to `.env` (gitignored) and fill in the values you need.
# Both are OPTIONAL: only set them if your sources are private.

# are.na — only required for private channels.
# Generate at: https://dev.are.na (Personal Access Token)
ARENA_TOKEN=

# Zotero — only required for private libraries.
# Generate a read-only key at: https://www.zotero.org/settings/keys
ZOTERO_KEY=
