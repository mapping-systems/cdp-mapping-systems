# Copy this file to `.env` (gitignored) and fill in what you need.

# are.na — only required for private channels; public ones work without.
# Generate at: https://dev.are.na (Personal Access Token)
ARENA_TOKEN=

# GitHub — REQUIRED for fetching Star Lists. Easiest:
#   GITHUB_TOKEN=$(gh auth token)
# Or generate a fine-grained token with `public_repo` + `read:user` scopes at
# https://github.com/settings/tokens
GITHUB_TOKEN=

# Zotero — only required for private libraries; public ones work without.
# Generate a read-only key at https://www.zotero.org/settings/keys
ZOTERO_KEY=
